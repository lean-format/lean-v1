{
  "name": "lean-format-monorepo",
  "version": "2.0.0",
  "description": "LEAN Format - Complete project repository",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/cli",
    "packages/vscode",
    "packages/lean-language-server",
    "packages/playground",
    "packages/website",
    "packages/lean-format"
  ],
  "scripts": {
    "build": "npm run build:rust && npm run build:ts",
    "build:ts": "tsc -b packages/core packages/cli packages/lean-language-server",
    "build:rust": "cd packages/lean-parser-rs && wasm-pack build --target bundler --out-dir pkg 2>/dev/null || echo 'Rust/WASM build skipped (install wasm-pack)'",
    "build:vscode": "npm run build -w packages/vscode",
    "build:playground": "npm run build -w packages/playground",
    "build:website": "npm run build -w packages/website",
    "clean": "rm -rf packages/*/dist packages/*/node_modules node_modules",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint packages/",
    "typecheck": "npm run typecheck -w packages/core -w packages/cli -w packages/lean-language-server",
    "format": "prettier --write \"packages/*/src/**/*.{ts,js,tsx,jsx}\"",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@vitest/coverage-v8": "^3.1.3",
    "typescript": "^5.9.3",
    "vitest": "^3.1.3",
    "eslint": "^9.26.0",
    "prettier": "^3.5.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
