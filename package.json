{
  "name": "lean-format-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "LEAN Format monorepo",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "build:core": "pnpm --filter @lean-format/core build",
    "build:editor": "pnpm --filter @lean-format/editor build",
    "build:ui": "pnpm --filter @lean-format/ui build",
    "build:playground": "pnpm --filter @lean-format/playground build",
    "build:spec-docs": "pnpm --filter @lean-format/spec-docs build",
    "build:cli": "pnpm --filter @lean-format/cli build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx,js,jsx,mjs}\""
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
