{
  "name": "@lean-format/core",
  "version": "0.0.0",
  "description": "LEAN Format parser core - WASM-compiled parser with JS fallback",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "wasm"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no linter configured'"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
