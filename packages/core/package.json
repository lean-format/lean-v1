{
  "name": "@lean-format/core",
  "version": "2.0.0",
  "description": "LEAN (Lightweight Efficient Adaptive Notation) - A minimal, human-readable data interchange format",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test",
    "docs": "typedoc src/index.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "lean-parser-rs": "file:../lean-parser-rs/pkg"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^3.1.3",
    "eslint": "^9.26.0",
    "typedoc": "^0.28.0"
  },
  "keywords": [
    "lean",
    "format",
    "data",
    "notation",
    "parser",
    "serializer",
    "json",
    "yaml",
    "csv",
    "interchange",
    "compact",
    "human-readable"
  ],
  "author": "LEAN Format Team",
  "license": "MIT",
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lean-format/lean-v1.git"
  },
  "bugs": {
    "url": "https://github.com/lean-format/lean-v1/issues"
  },
  "homepage": "https://lean-format.github.io/lean-v1/"
}
