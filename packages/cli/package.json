{
  "name": "@lean-format/cli",
  "version": "2.1.0",
  "author": "LEAN Format Team",
  "license": "MIT",
  "description": "Command line interface for the LEAN data format",
  "type": "module",
  "bin": {
    "lean": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "node --loader ts-node/esm src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@iarna/toml": "^3.0.0",
    "@lean-format/core": "^2.1.0",
    "better-sqlite3": "^12.11.1",
