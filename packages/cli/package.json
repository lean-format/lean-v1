{
  "name": "@lean-format/cli",
  "version": "2.0.0",
  "author": "LEAN Format Team",
  "license": "MIT",
  "description": "Command line interface for the LEAN data format",
  "type": "module",
  "bin": {
    "lean": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "node --loader ts-node/esm src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lean-format/core": "^2.0.0",
    "commander": "^13.1.0",
    "js-yaml": "^4.1.0",
    "@iarna/toml": "^3.0.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^3.1.3",
    "@types/node": "^22.15.3",
    "@types/js-yaml": "^4.0.9"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lean-format/lean-v1.git"
  },
  "bugs": {
    "url": "https://github.com/lean-format/lean-v1/issues"
