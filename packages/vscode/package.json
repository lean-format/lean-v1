{
  "name": "lean-format-vscode",
  "displayName": "LEAN Format Support",
  "description": "Syntax highlighting, formatting, and validation for LEAN (Lightweight Efficient Adaptive Notation) format",
  "version": "2.1.0",
  "author": "LEAN Format Team",
  "publisher": "lean-format",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/lean-format/lean-v1.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Linters"
  ],
  "keywords": [
    "lean",
    "data",
    "format",
    "notation",
    "syntax"
  ],
  "activationEvents": [
    "onLanguage:lean"
  ],
  "contributes": {
    "languages": [
      {
        "id": "lean",
        "aliases": [
          "LEAN",
          "lean"
        ],
        "extensions": [
          ".lean"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./images/icon-light.png",
          "dark": "./images/icon-dark.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "lean",
        "scopeName": "source.lean",
        "path": "./syntaxes/lean.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "lean",
        "path": "./snippets/lean.json"
      }
    ],
    "commands": [
      {
        "command": "lean.convertToJson",
        "title": "LEAN: Convert to JSON"
      }
    ],
    "configuration": {
      "title": "LEAN Format",
      "properties": {
        "lean.format.indentSize": {
          "type": "number",
          "default": 2,
          "enum": [
            2,
            4
          ],
          "description": "Number of spaces for indentation"
        },
        "lean.format.useRowSyntax": {
          "type": "boolean",
          "default": true,
          "description": "Use row syntax for arrays of objects"
        },
        "lean.format.rowThreshold": {
          "type": "number",
          "default": 4,
          "minimum": 1,
          "description": "Minimum number of items to trigger row syntax"
        },
        "lean.format.sortKeys": {
          "type": "boolean",
          "default": false,
          "description": "Sort keys alphabetically on format"
        },
        "lean.format.useDotNotation": {
          "type": "boolean",
          "default": false,
          "description": "Use dot notation for nested keys (may break round-trip)"
        },
        "lean.validate.strict": {
          "type": "boolean",
          "default": false,
          "description": "Enable strict validation (duplicate key detection, etc.)"
        }
      }
    },
    "configurationDefaults": {
      "[lean]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.detectIndentation": true,
        "editor.formatOnSave": false
      }
    }
  },
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node build.js",
    "watch": "node build.js --watch",
    "package": "npm run compile -- --production",
    "package:vsix": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies",
    "test": "node test.js"
  },
  "dependencies": {
    "@lean-format/core": "^2.1.0",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.25.4",
    "vsce": "^2.15.0"
  }
}
