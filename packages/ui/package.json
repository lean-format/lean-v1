{
  "name": "@lean-format/ui",
  "version": "0.0.0",
  "description": "React component library for LEAN Format",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles/globals.css": "./dist/styles/globals.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build && mkdir -p dist/styles && cp src/styles/globals.css dist/styles/globals.css",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no linter configured'"
  },
  "dependencies": {
    "@codemirror/language": "^6.11.0",
    "@codemirror/lint": "^6.8.5",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.35.0",
    "@lean-format/core": "workspace:*",
    "@lean-format/editor": "workspace:*",
    "@lezer/common": "^1.2.3",
    "@lezer/highlight": "^1.2.1",
    "codemirror": "^6.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^6.3.3"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  }
}
