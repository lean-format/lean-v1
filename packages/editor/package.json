{
  "name": "@lean-format/editor",
  "version": "0.0.0",
  "description": "CodeMirror 6 extension for LEAN Format with Lezer grammar",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "lezer-generator lean.grammar -o src/grammar && tsup",
    "clean": "rm -rf dist src/grammar.ts",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no linter configured'"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/language": "^6.11.0",
    "@codemirror/lint": "^6.8.5",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.35.0",
    "@lean-format/core": "workspace:*",
    "@lezer/common": "^1.2.3",
    "@lezer/highlight": "^1.2.1",
    "@lezer/lr": "^1.4.2"
  },
  "devDependencies": {
    "@lezer/generator": "^1.7.3",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3"
  }
}
